# Common
DEFAULT_PROVIDER=mock
DEFAULT_MODEL=
LLM_MAX_RETRIES=1
LLM_TIMEOUT_SECONDS=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Persistence
# Local development defaults to SQLite under data/pz_deep_research.db.
# Production can use: postgresql://user:password@host:5432/database
DATABASE_URL=

# OpenAI / ChatGPT API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MODEL_OPTIONS=gpt-5.4-mini,gpt-5.5,gpt-5.4,gpt-5.4-nano,gpt-5-mini,gpt-5-nano

# Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Research tools
SEARCH_PROVIDER=serpapi
ACADEMIC_SEARCH_ENGINE=google_scholar
SERPAPI_API_KEY=
JINA_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
